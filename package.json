{
  "name": "mcp-sentinel",
  "version": "1.0.0",
  "description": "MCP Security Posture Management & Detonation Platform",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces --if-present",
    "test:integration": "node scripts/integration-test.js",
    "dev:web": "npm run dev --workspace=packages/web",
    "dev:api": "npm run dev --workspace=packages/evidence",
    "lint": "eslint packages/*/src/**/*.ts"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT",
  "author": "Yuki"
}
